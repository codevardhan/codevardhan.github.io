---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  usemathjax?: boolean;
}
const { title = "codevardhan", description = "Portfolio of Harsh — AI engineer & software tinkerer", usemathjax = false } = Astro.props;
---
<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/png" href="/images/favicon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&family=Inter:wght@300..700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
  {usemathjax && (
    <script src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js" is:inline></script>
  )}
</head>
<body class="min-h-screen flex flex-col bg-surface text-on-surface font-body ai-grid">

  <!-- Navigation -->
  <nav class="fixed top-0 w-full z-50 bg-surface/80 backdrop-blur-md shadow-[0_20px_40px_rgba(173,198,255,0.04)]" style="border-bottom:1px solid rgba(255,255,255,0.05)">
    <div class="flex justify-between items-center px-6 py-4 max-w-7xl mx-auto">
      <a href="/" class="text-xl font-bold tracking-tighter text-white uppercase font-headline flex items-center gap-2 no-underline hover:text-primary transition-colors">
        <span class="material-symbols-outlined text-primary" style="font-variation-settings:'FILL' 1">terminal</span>
        Codevardhan
      </a>
      <!-- Desktop links -->
      <div class="hidden md:flex items-center gap-8 font-headline tracking-tight text-sm">
        <a href="/#projects" class="text-on-surface-variant hover:text-white transition-colors no-underline">Projects</a>
        <a href="/posts" class="text-on-surface-variant hover:text-white transition-colors no-underline">Blog</a>
        <a href="/#experience" class="text-on-surface-variant hover:text-white transition-colors no-underline">Experience</a>
        <a href="/#contact" class="text-on-surface-variant hover:text-white transition-colors no-underline">Contact</a>
        <a href="/resume" class="text-on-surface-variant hover:text-white transition-colors no-underline">Resume</a>
      </div>
      <a href="mailto:harsha7vardhan@gmail.com"
         class="hidden md:inline-flex bg-gradient-to-r from-primary to-primary-container text-on-primary-container px-5 py-2 rounded-md font-bold text-sm no-underline
                hover:shadow-[0_0_20px_rgba(221,183,255,0.3)] active:scale-95 transition-all">
        Hire Me
      </a>
      <!-- Mobile hamburger -->
      <button id="menu-toggle" class="md:hidden flex flex-col gap-1.5 p-2 text-on-surface-variant hover:text-white transition-colors" aria-label="Toggle menu">
        <span class="block w-6 h-0.5 bg-current transition-all duration-300" id="bar1"></span>
        <span class="block w-6 h-0.5 bg-current transition-all duration-300" id="bar2"></span>
        <span class="block w-4 h-0.5 bg-current transition-all duration-300" id="bar3"></span>
      </button>
    </div>
    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden px-6 pb-6 flex flex-col gap-4 font-headline text-sm" style="border-top:1px solid rgba(255,255,255,0.05)">
      <a href="/#projects" class="text-on-surface-variant hover:text-white transition-colors no-underline pt-4">Projects</a>
      <a href="/posts" class="text-on-surface-variant hover:text-white transition-colors no-underline">Blog</a>
      <a href="/#experience" class="text-on-surface-variant hover:text-white transition-colors no-underline">Experience</a>
      <a href="/#contact" class="text-on-surface-variant hover:text-white transition-colors no-underline">Contact</a>
      <a href="/resume" class="text-on-surface-variant hover:text-white transition-colors no-underline">Resume</a>
      <a href="mailto:harsha7vardhan@gmail.com"
         class="bg-gradient-to-r from-primary to-primary-container text-on-primary-container px-5 py-3 rounded-md font-bold text-sm no-underline text-center mt-2 active:scale-95 transition-all">
        Hire Me
      </a>
    </div>
  </nav>

  <script is:inline>
    var toggle = document.getElementById('menu-toggle');
    var menu = document.getElementById('mobile-menu');
    var bar3 = document.getElementById('bar3');
    toggle.addEventListener('click', function() {
      var open = menu.classList.toggle('hidden');
      bar3.style.width = open ? '1rem' : '1.5rem';
    });
    menu.querySelectorAll('a').forEach(function(a) {
      a.addEventListener('click', function() {
        menu.classList.add('hidden');
        bar3.style.width = '1rem';
      });
    });
  </script>

  <!-- Main content -->
  <main class="flex-1 pt-16">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="w-full py-12 px-8 bg-surface-container-lowest" style="border-top:1px solid rgba(255,255,255,0.05)">
    <div class="flex flex-col md:flex-row justify-between items-center gap-6 max-w-7xl mx-auto">
      <div class="hacker-text text-xs text-on-surface-variant opacity-50">
        © {new Date().getFullYear()} HARSHAVARDHAN. YES_I_WROTE_THIS_MYSELF.SYS
      </div>
      <div class="flex gap-8 font-mono text-xs uppercase tracking-widest">
        <a href="https://github.com/codevardhan" class="text-on-surface-variant hover:text-primary transition-colors opacity-80 hover:opacity-100 no-underline">GitHub</a>
        <a href="https://linkedin.com/in/codevardhan" class="text-on-surface-variant hover:text-primary transition-colors opacity-80 hover:opacity-100 no-underline">LinkedIn</a>
        <a href="https://instagram.com/h_v_m_" class="text-on-surface-variant hover:text-primary transition-colors opacity-80 hover:opacity-100 no-underline">Instagram</a>
      </div>
    </div>
  </footer>

  <!-- Mermaid lazy-load -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      var KW = /^\s*(graph |flowchart |sequenceDiagram|classDiagram|stateDiagram|erDiagram|gantt|pie |quadrantChart|xychart|mindmap|timeline|gitGraph|sankey)/;
      var pres = document.querySelectorAll('pre');
      var targets = [];
      pres.forEach(function(pre) { if (KW.test(pre.textContent)) targets.push(pre); });
      if (targets.length === 0) return;
      var s = document.createElement('script');
      s.src = 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js';
      s.onload = function() {
        targets.forEach(function(pre) {
          var div = document.createElement('div');
          div.className = 'mermaid';
          div.textContent = pre.textContent;
          pre.replaceWith(div);
        });
        mermaid.initialize({ startOnLoad: true, theme: 'dark', themeVariables: { primaryColor: '#b76dff', primaryTextColor: '#dae2fd', lineColor: '#4d4354', secondaryColor: '#131b2e' }});
        mermaid.run();
      };
      document.head.appendChild(s);
    });
  </script>
</body>
</html>