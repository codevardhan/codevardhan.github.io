---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  image?: string;
  tags?: string[];
  usemathjax?: boolean;
}

const { title, date, image, tags = [], usemathjax = false } = Astro.props;
const dateStr = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const readTime = Math.max(1, Math.ceil((Astro.props as any).minutesRead || 5));
---
<BaseLayout title={`${title} — Harsh`} usemathjax={usemathjax}>
  <article class="max-w-3xl mx-auto px-6 py-12">
    <!-- Header -->
    <header class="mb-10">
      {image && <img src={image} alt={title} class="w-full h-64 object-cover rounded-xl mb-6" />}
      <h1 class="text-3xl md:text-4xl font-bold text-gray-100 leading-tight">{title}</h1>
      <div class="flex items-center gap-4 mt-4 text-sm text-gray-500">
        <time datetime={date.toISOString()}>{dateStr}</time>
        <span>&middot;</span>
        <span>{readTime} min read</span>
      </div>
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {tags.map(tag => (
            <span class="px-2.5 py-0.5 text-xs font-medium bg-gray-800 text-purple-300 rounded-full">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <!-- Content -->
    <div class="prose">
      <slot />
    </div>

    <!-- Back link -->
    <div class="mt-12 pt-6 border-t border-gray-800">
      <a href="javascript:history.back()" class="text-sm text-gray-500 hover:text-accent no-underline">&larr; Go back</a>
    </div>
  </article>
</BaseLayout>
