---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<BaseLayout title="Blog — Harsh">
  <div class="max-w-3xl mx-auto px-6 py-12">
    <h1 class="text-3xl font-bold mb-8 text-gray-100">Blog</h1>
    <div class="space-y-8">
      {posts.map(post => (
        <a href={`/posts/${post.slug}`} class="group flex gap-6 items-start no-underline">
          {post.data.image && (
            <img src={post.data.image} alt={post.data.title} class="w-32 h-24 object-cover rounded-lg flex-shrink-0 hidden sm:block" />
          )}
          <div>
            <h2 class="text-xl font-semibold text-gray-100 group-hover:text-accent transition">{post.data.title}</h2>
            <time class="text-sm text-gray-500 mt-1 block" datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            <div class="flex flex-wrap gap-1.5 mt-2">
              {(post.data.tags || []).map(tag => (
                <span class="px-2 py-0.5 text-xs bg-gray-800 text-gray-500 rounded">{tag}</span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
